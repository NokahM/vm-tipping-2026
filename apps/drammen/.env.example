# Kopier denne filen til .env.local og fyll inn din egen nøkkel.
# Hent nøkkel gratis på https://www.football-data.org/client/register
#
# Nøkkelen brukes kun server-side (Vite dev-proxy / Vercel-funksjon),
# så den eksponeres ikke i nettleseren. Foretrukket variabelnavn:
FOOTBALL_API_KEY=

# (Eldre navn støttes også som fallback:)
# VITE_FOOTBALL_API_KEY=

# Admin-passord. Sjekkes KUN server-side (api/state.js + dev-proxyen) – havner aldri
# i nettleser-bundelen. Sett et langt, tilfeldig passord. (Det finnes ingen VITE_-variant;
# admin-porten verifiserer mot serveren, ikke mot en innebygd verdi.)
ADMIN_PASSWORD=
